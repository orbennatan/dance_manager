{
  "version": "0.2.0",
  "configurations": [

    {
      "name": "Run Dance Manager",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Debug Dance Manager",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "console": "integratedTerminal",
      "justMyCode": false,
      "debugAdapterPath": "${workspaceFolder}/.venv/Scripts/python.exe"
    }
  ]
}
